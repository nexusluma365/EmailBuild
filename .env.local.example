# ─── Google OAuth ───────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── NextAuth ────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── For Netlify production, set NEXTAUTH_URL to your live domain ────
# NEXTAUTH_URL=https://your-site.netlify.app

# ─── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Referral import / automation ──────────────────────────────────────
# This URL must return referral rows as JSON. Your current Apps Script writes
# rows but does not expose them for reading yet, so add a read endpoint first.
REFERRAL_SOURCE_URL=https://your-referral-source.example.com/referrals

# Optional: use a secret if you trigger campaign automation from a cron job.
# The due-campaign runner endpoint is POST /api/campaigns/run-due
CRON_SECRET=your_long_random_secret
AUTOMATION_OWNER_EMAIL=you@example.com
